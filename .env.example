# Discord app credentials
DISCORD_APP_ID=
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=

# Optional: register commands to a single guild for faster updates
DISCORD_COMMAND_GUILD_ID=

# Access settings
ACCESS_FRONTEND_BASE_URL=https://accessbot.governance.so
RPC_ENDPOINT=https://api.mainnet-beta.solana.com
CLUSTER=mainnet-beta
CHECK_MODE=simulate
ONCHAIN_CHECKER_KEYPAIR_PATH=

# Revalidation + sync behavior
DEFAULT_RECHECK_INTERVAL_SEC=86400
DRY_RUN_SYNC=false
MAX_SYNC_JOBS_PER_CRON=3
MAX_USERS_PER_SYNC=500

# Optional security for callback and cron
VERIFY_SHARED_SECRET=
CRON_SECRET=

# Optional bootstrap mappings (JSON array)
# Example:
# [{"guildId":"123","gateId":"abc","daoId":"my-dao","passRoleId":"456","failAction":"remove_role","enabled":true}]
BOOTSTRAP_GATES_JSON=

LOG_LEVEL=info
